---
import { education, honoursAwardsScholarships, seasonalSchools } from '../data/academic';
import AcademicPage from '../layouts/AcademicPage.astro';
---

<AcademicPage
	currentPath="/record/"
	title="Academic Record"
	description="Academic training, seasonal schools, and honours, awards and scholarships for Maximos Skandalis."
	eyebrow="04 / Academic record"
	heading="Training across"
	emphasis="disciplines."
	intro="A path across artificial intelligence, mathematical logic, history and philosophy of science, classics, and linguistics."
>
	<section class="page-section" aria-labelledby="education-heading">
		<div class="page-section-label"><span>Education</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="education-heading">Academic training</h2>
			<div class="academic-list">
				{
					education.map((item) => (
						<article class="academic-item">
							<div class="academic-meta"><span>{item.year}</span><span>Degree</span></div>
							<div>
								<h3>{item.title}</h3>
								<p>{item.detail}</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="page-section" aria-labelledby="schools-heading">
		<div class="page-section-label"><span>Seasonal schools</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="schools-heading">Seasonal <em>schools.</em></h2>
			<div class="academic-list">
				{
					seasonalSchools.map((school) => (
						<article class="academic-item">
							<div class="academic-meta"><span>{school.period}</span><span>School</span></div>
							<div>
								<h3>{school.title}</h3>
								<p>{school.detail}</p>
							</div>
							{school.href && <a class="academic-link" href={school.href} target="_blank" rel="noreferrer">{school.linkLabel}</a>}
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="page-section" aria-labelledby="honours-heading">
		<div class="page-section-label"><span>Honours</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="honours-heading">Honours, awards & <em>scholarships.</em></h2>
			<div class="academic-list">
				{
					honoursAwardsScholarships.map((award) => (
						<article class="academic-item">
							<div class="academic-meta"><span>{award.period}</span><span>Honour</span></div>
							<div>
								<h3>{award.title}</h3>
								<p>{award.detail}</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>
</AcademicPage>