---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { education, newsItems, publications, researchDirections } from '../data/academic';

const selectedPublications = publications.slice(0, 3).map((publication, index) => ({
	index: `P.${publication.year.slice(-2)}`,
	kind: publication.role,
	title: publication.title,
	description: publication.summary,
	status: publication.linkLabel,
	href: publication.href,
}));
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="The academic portfolio of Maximos Skandalis, a PhD researcher in AI at LIRMM, CNRS and the University of Montpellier."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap"
			rel="stylesheet"
		/>
		<title>Maximos Skandalis - AI Research</title>
	</head>
	<body>
		<div class="site-shell">
			<SiteHeader currentPath="/" />

			<main>
				<section class="intro-grid" aria-labelledby="intro-heading">
					<div class="hero-copy">
						<div class="eyebrow">LIRMM / CNRS / Montpellier</div>
						<h1 class="hero-heading" id="intro-heading">Maximos <em>Skandalis</em></h1>
						<div class="hero-bottom">
							<p class="hero-summary">Neurosymbolic AI for natural language inference and automatic contradiction detection.</p>
							<div class="current-status">
								<strong>Current focus</strong>
								LLMs, logic, linguistic formalisms, and reliable language technology.
							</div>
						</div>
					</div>
					<figure class="portrait-panel">
						<div class="portrait-frame">
							<img class="portrait-image" src="/images/portrait.png" alt="Portrait of Maximos Skandalis" />
						</div>
						<figcaption class="portrait-caption">
							<span>Portrait / 01</span>
							<span>AI researcher / 2026</span>
						</figcaption>
					</figure>
				</section>

				<section class="section" id="about" aria-labelledby="about-heading">
					<div class="section-label">
						<div class="section-kicker"><span class="section-number">01</span><span>About</span></div>
					</div>
					<div class="section-content about-layout">
						<h2 class="section-title" id="about-heading">Language reasoning, made <em>rigorous.</em></h2>
						<div>
							<p class="prose">
								I am a last-year PhD student in AI at LIRMM, CNRS and the University of Montpellier.
								My research combines LLMs with logic and linguistic formalisms for natural language inference
								and automatic contradiction detection.
							</p>
							<p class="prose">
								I am especially interested in reliable language technologies for high-stakes applications, where
								formal reasoning and careful evaluation matter as much as raw capability.
							</p>
							<div class="small-stack" style="margin-top: 2.5rem">
								<div>
									<div class="micro-label">Doctoral funding</div>
									<p>French Ministry of the Armed Forces through the Defence Innovation Agency, and the Cybersecurity Institute of Occitanie.</p>
								</div>
								<div>
									<div class="micro-label">Research environment</div>
									<p>LIRMM, CNRS and the University of Montpellier, France.</p>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="section" id="research" aria-labelledby="research-heading">
					<div class="section-label">
						<div class="section-kicker"><span class="section-number">02</span><span>Research / publications</span></div>
					</div>
					<div class="section-content">
						<div class="research-header">
							<h2 class="section-title" id="research-heading">Research with <em>consequences.</em></h2>
							<p class="research-note">
								A research agenda grounded in formal methods, linguistic structure, and the practical demands of
								reliable natural language technology.
							</p>
						</div>
						<div class="project-grid">
							{
								researchDirections.map((direction) => (
									<article class="project-card">
										<div>
											<div class="project-card-top">
												<span class="work-index">{direction.index}</span>
												<span class="micro-label">{direction.kind}</span>
											</div>
											<h3>{direction.title}</h3>
											<p>{direction.description}</p>
										</div>
										<div class="card-footer">
											<span class="tag">{direction.status}</span>
											<span class="link-arrow" aria-hidden="true"></span>
										</div>
									</article>
								))
							}
						</div>
						<div class="research-header" style="margin-top: 4rem">
							<div>
								<div class="micro-label">Selected first-author papers</div>
								<h3 class="section-title" style="margin-top: 0.8rem">Work made <em>public.</em></h3>
							</div>
							<p class="research-note">A selection of peer-reviewed work on neurosymbolic natural language inference and contradiction detection.</p>
						</div>
						<div class="project-grid">
							{
								selectedPublications.map((publication) => (
									<a class="project-card" href={publication.href} target="_blank" rel="noreferrer">
										<div>
											<div class="project-card-top">
												<span class="work-index">{publication.index}</span>
												<span class="micro-label">{publication.kind}</span>
											</div>
											<h3>{publication.title}</h3>
											<p>{publication.description}</p>
										</div>
										<div class="card-footer">
											<span class="tag">{publication.status}</span>
											<span class="link-arrow" aria-hidden="true"></span>
										</div>
									</a>
								))
							}
						</div>
					</div>
				</section>

				<section class="section" id="record" aria-labelledby="record-heading">
					<div class="section-label">
						<div class="section-kicker"><span class="section-number">03</span><span>Academic record</span></div>
					</div>
					<div class="section-content">
						<div class="record-grid">
							<div>
								<h2 class="section-title" id="record-heading">Training across <em>disciplines.</em></h2>
								<div class="timeline" style="margin-top: 2.5rem">
									{
										education.map((item) => (
											<article class="timeline-item">
												<div class="timeline-year">{item.year}</div>
												<div class="timeline-copy">
													<h3>{item.title}</h3>
													<p>{item.detail}</p>
												</div>
											</article>
										))
									}
								</div>
							</div>
							<div class="record-aside" aria-label="Academic record categories">
								<a class="record-card" href="/record/">
									<div class="micro-label">Education</div>
									<h3>Four degrees</h3>
									<p>AI, mathematical logic, history and philosophy of science, classics and linguistics.</p>
								</a>
								<a class="record-card" href="/teaching/">
									<div class="micro-label">Teaching</div>
									<h3>272 teaching hours</h3>
									<p>Lectures, tutorials, practical sessions, and student research supervision.</p>
								</a>
								<a class="record-card" href="/responsibilities/">
									<div class="micro-label">Responsibilities</div>
									<h3>Academic work in practice</h3>
									<p>Research, teaching, supervision, and publicly supported language AI.</p>
								</a>
							</div>
						</div>
					</div>
				</section>

				<section class="section" id="notes" aria-labelledby="notes-heading">
					<div class="section-label">
						<div class="section-kicker"><span class="section-number">04</span><span>Blog / news</span></div>
					</div>
					<div class="section-content">
						<div class="notes-layout">
							<div class="notes-heading">
								<div class="micro-label">Signal log</div>
								<h2 class="section-title" id="notes-heading">Thinking, out <em>loud.</em></h2>
								<p>Recent talks, research activity, and short notes from the workbench.</p>
							</div>
							<div class="entry-list">
								{
									newsItems.map((note) => (
										<a class="entry" href={note.href} target={note.href.startsWith('http') ? '_blank' : undefined} rel={note.href.startsWith('http') ? 'noreferrer' : undefined}>
											<span class="entry-date">{note.date}</span>
											<span class="entry-title">{note.title}</span>
											<span class="entry-status">{note.status}</span>
										</a>
									))
								}
							</div>
						</div>
					</div>
				</section>

				<section class="cv-band" aria-labelledby="cv-heading">
					<div>
						<div class="section-kicker"><span class="section-number">05</span><span>Curriculum vitae</span></div>
						<h2 class="section-title" id="cv-heading" style="margin-top: 1.25rem">The full record, <em>in one place.</em></h2>
						<p>
							Research, education, talks, funding, and scholarly output collected in a focused, printable format.
						</p>
					</div>
					<a class="cv-link link-arrow" href="/cv/">Open CV</a>
				</section>
			</main>

			<SiteFooter />
		</div>
	</body>
</html>
