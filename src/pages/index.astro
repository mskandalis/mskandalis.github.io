---
import { existsSync } from 'node:fs';
import '../styles/global.css';

const portraitPath = new URL('../../public/images/portrait.png', import.meta.url);
const hasPortrait = existsSync(portraitPath);

const researchDirections = [
	{
		index: 'R.01',
		kind: 'Research direction',
		title: 'Neurosymbolic NLI',
		description:
			'Combining large language models with logic and linguistic formalisms for semantic parsing and natural language reasoning.',
		status: 'Core focus',
	},
	{
		index: 'R.02',
		kind: 'Research direction',
		title: 'Contradiction detection',
		description:
			'Robust automatic detection of textual entailment and contradictions, with special attention to French-language resources.',
		status: 'Active research',
	},
	{
		index: 'R.03',
		kind: 'Research direction',
		title: 'High-stakes language AI',
		description:
			'Bringing formal methods, reliable data, and language technology together for consequential application domains.',
		status: 'Applied inquiry',
	},
];

const selectedPublications = [
	{
		index: 'P.25',
		kind: 'First author',
		title: 'Neurosymbolic AI for Natural Language Inference in French',
		description: 'IWCS 2025. Combining LLMs and theorem provers for semantic parsing and natural language reasoning.',
		status: 'Read paper',
		href: 'https://aclanthology.org/2025.iwcs-main.21',
	},
	{
		index: 'P.24',
		kind: 'First author',
		title: 'New Datasets for Automatic Detection of Textual Entailment',
		description: 'LREC-COLING 2024. French datasets for textual entailment and contradiction detection.',
		status: 'Read paper',
		href: 'https://aclanthology.org/2024.lrec-main.1065',
	},
	{
		index: 'P.23',
		kind: 'First author',
		title: 'DACCORD',
		description: 'TALN 2023. A French dataset for automatic detection of contradictory statements.',
		status: 'Read paper',
		href: 'https://aclanthology.org/2023.jeptalnrecital-long.22',
	},
];

const recordItems = [
	{
		year: 'Now',
		title: 'Ph.D. in computer science and AI',
		detail: 'Last-year Ph.D. researcher at LIRMM, CNRS and the University of Montpellier.',
	},
	{
		year: 'M.S.',
		title: 'Mathematical logic and theoretical computer science',
		detail: 'Paris Cité University, France.',
	},
	{
		year: 'M.A.',
		title: 'History and philosophy of science',
		detail: 'École normale supérieure de Paris (ENS Ulm), France.',
	},
	{
		year: 'Ptychio',
		title: 'Classics and linguistics',
		detail: 'Aristotle University of Thessaloniki, Greece.',
	},
];

const newsItems = [
	{
		date: '2025.12',
		title: 'Deep learning and formal methods for contradiction detection',
		status: 'ICO annual scientific day',
		href: 'https://www.ico-occitanie.fr/wp-content/uploads/2025/07/Programme-Journee-ICO-2025-C.pdf#page=6',
	},
	{
		date: '2025.11',
		title: 'Data quality and neurosymbolic approaches to textual inference',
		status: 'RECAST thematic workshop',
		href: 'https://gt-recast.github.io/events/2025-11-17.html',
	},
	{
		date: '2026.07',
		title: 'A new research notebook for papers, projects, and field notes.',
		status: 'Site update',
		href: '#about',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="The academic portfolio of Maximos Skandalis, a Ph.D. researcher in AI at LIRMM, CNRS and the University of Montpellier."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap"
			rel="stylesheet"
		/>
		<title>Maximos Skandalis - AI Research</title>
	</head>
	<body>
		<div class="site-shell">
			<header class="site-header">
				<a class="wordmark" href="/" aria-label="Maximos Skandalis home">
					<span class="wordmark-mark">MS</span>
					<span>Maximos Skandalis</span>
				</a>
				<nav class="site-nav" aria-label="Primary navigation">
					<a class="nav-link" href="#about">About</a>
					<a class="nav-link" href="#research">Research</a>
					<a class="nav-link" href="#record">Record</a>
					<a class="nav-link" href="#notes">Notes</a>
				</nav>
				<a class="header-link" href="/cv/">CV</a>
			</header>

			<main>
				<section class="intro-grid" aria-labelledby="intro-heading">
					<div class="hero-copy">
						<div class="eyebrow">LIRMM / CNRS / Montpellier</div>
						<h1 class="hero-heading" id="intro-heading">Maximos <em>Skandalis</em></h1>
						<div class="hero-bottom">
							<p class="hero-summary">Neurosymbolic AI for natural language inference and automatic contradiction detection.</p>
							<div class="current-status">
								<strong>Current focus</strong>
								LLMs, logic, linguistic formalisms, and reliable language technology.
							</div>
						</div>
					</div>
					<figure class="portrait-panel">
						<div class="portrait-frame">
							{
								hasPortrait ? (
									<img
										class="portrait-image"
										src="/images/portrait.png"
										alt="Portrait of Maximos Skandalis"
									/>
								) : (
									<div class="portrait-fallback" aria-label="Portrait placeholder for Maximos Skandalis" role="img">
										M<span>image / 01</span>
									</div>
								)
							}
						</div>
						<figcaption class="portrait-caption">
							<span>Portrait / 01</span>
							<span>AI researcher / 2026</span>
						</figcaption>
					</figure>
				</section>

				<section class="section" id="about" aria-labelledby="about-heading">
					<div class="section-label">
						<div class="section-kicker"><span class="section-number">01</span><span>About</span></div>
					</div>
					<div class="section-content about-layout">
						<h2 class="section-title" id="about-heading">Language reasoning, made <em>rigorous.</em></h2>
						<div>
							<p class="prose">
								I am a last-year Ph.D. student in AI at LIRMM, CNRS and the University of Montpellier.
								My research combines LLMs with logic and linguistic formalisms for natural language inference
								and automatic contradiction detection.
							</p>
							<p class="prose">
								I am especially interested in reliable language technologies for high-stakes applications, where
								formal reasoning and careful evaluation matter as much as raw capability.
							</p>
							<div class="small-stack" style="margin-top: 2.5rem">
								<div>
									<div class="micro-label">Doctoral funding</div>
									<p>French Ministry of the Armed Forces through the Defence Innovation Agency, and the Cybersecurity Institute of Occitanie.</p>
								</div>
								<div>
									<div class="micro-label">Research environment</div>
									<p>LIRMM, CNRS and the University of Montpellier, France.</p>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="section" id="research" aria-labelledby="research-heading">
					<div class="section-label">
						<div class="section-kicker"><span class="section-number">02</span><span>Research / publications</span></div>
					</div>
					<div class="section-content">
						<div class="research-header">
							<h2 class="section-title" id="research-heading">Research with <em>consequences.</em></h2>
							<p class="research-note">
								A research agenda grounded in formal methods, linguistic structure, and the practical demands of
								reliable natural language technology.
							</p>
						</div>
						<div class="project-grid">
							{
								researchDirections.map((direction) => (
									<article class="project-card">
										<div>
											<div class="project-card-top">
												<span class="work-index">{direction.index}</span>
												<span class="micro-label">{direction.kind}</span>
											</div>
											<h3>{direction.title}</h3>
											<p>{direction.description}</p>
										</div>
										<div class="card-footer">
											<span class="tag">{direction.status}</span>
											<span class="link-arrow" aria-hidden="true"></span>
										</div>
									</article>
								))
							}
						</div>
						<div class="research-header" style="margin-top: 4rem">
							<div>
								<div class="micro-label">Selected first-author papers</div>
								<h3 class="section-title" style="margin-top: 0.8rem">Work made <em>public.</em></h3>
							</div>
							<p class="research-note">A selection of peer-reviewed work on neurosymbolic natural language inference and contradiction detection.</p>
						</div>
						<div class="project-grid">
							{
								selectedPublications.map((publication) => (
									<a class="project-card" href={publication.href} target="_blank" rel="noreferrer">
										<div>
											<div class="project-card-top">
												<span class="work-index">{publication.index}</span>
												<span class="micro-label">{publication.kind}</span>
											</div>
											<h3>{publication.title}</h3>
											<p>{publication.description}</p>
										</div>
										<div class="card-footer">
											<span class="tag">{publication.status}</span>
											<span class="link-arrow" aria-hidden="true"></span>
										</div>
									</a>
								))
							}
						</div>
					</div>
				</section>

				<section class="section" id="record" aria-labelledby="record-heading">
					<div class="section-label">
						<div class="section-kicker"><span class="section-number">03</span><span>Academic record</span></div>
					</div>
					<div class="section-content">
						<div class="record-grid">
							<div>
								<h2 class="section-title" id="record-heading">Training across <em>disciplines.</em></h2>
								<div class="timeline" style="margin-top: 2.5rem">
									{
										recordItems.map((item) => (
											<article class="timeline-item">
												<div class="timeline-year">{item.year}</div>
												<div class="timeline-copy">
													<h3>{item.title}</h3>
													<p>{item.detail}</p>
												</div>
											</article>
										))
									}
								</div>
							</div>
							<div class="record-aside" aria-label="Academic record categories">
								<article class="record-card">
									<div class="micro-label">Education</div>
									<h3>Four degrees</h3>
									<p>AI, mathematical logic, history and philosophy of science, classics and linguistics.</p>
								</article>
								<article class="record-card">
									<div class="micro-label">Research talks</div>
									<h3>Scientific exchange</h3>
									<p>Oral presentations at the ICO Annual Scientific Day and the RECAST thematic workshop.</p>
								</article>
								<article class="record-card">
									<div class="micro-label">Funding</div>
									<h3>Public-interest AI</h3>
									<p>Funded by the Defence Innovation Agency and the Cybersecurity Institute of Occitanie.</p>
								</article>
							</div>
						</div>
					</div>
				</section>

				<section class="section" id="notes" aria-labelledby="notes-heading">
					<div class="section-label">
						<div class="section-kicker"><span class="section-number">04</span><span>Blog / news</span></div>
					</div>
					<div class="section-content">
						<div class="notes-layout">
							<div class="notes-heading">
								<div class="micro-label">Signal log</div>
								<h2 class="section-title" id="notes-heading">Thinking, out <em>loud.</em></h2>
								<p>Recent talks, research activity, and short notes from the workbench.</p>
							</div>
							<div class="entry-list">
								{
									newsItems.map((note) => (
										<a class="entry" href={note.href} target={note.href.startsWith('http') ? '_blank' : undefined} rel={note.href.startsWith('http') ? 'noreferrer' : undefined}>
											<span class="entry-date">{note.date}</span>
											<span class="entry-title">{note.title}</span>
											<span class="entry-status">{note.status}</span>
										</a>
									))
								}
							</div>
						</div>
					</div>
				</section>

				<section class="cv-band" aria-labelledby="cv-heading">
					<div>
						<div class="section-kicker"><span class="section-number">05</span><span>Curriculum vitae</span></div>
						<h2 class="section-title" id="cv-heading" style="margin-top: 1.25rem">The full record, <em>in one place.</em></h2>
						<p>
							Research, education, talks, funding, and scholarly output collected in a focused, printable format.
						</p>
					</div>
					<a class="cv-link link-arrow" href="/cv/">Open CV</a>
				</section>
			</main>

			<footer class="site-footer">
				<span class="footer-note">Maximos Skandalis / Research portfolio / 2026</span>
				<div class="footer-links">
					<a class="text-link" href="mailto:maximos.skandalis@cnrs.fr">Email</a>
					<a class="text-link" href="https://github.com/mskandalis" target="_blank" rel="noreferrer">GitHub</a>
					<a class="text-link" href="https://www.linkedin.com/in/maximos-skandalis" target="_blank" rel="noreferrer">LinkedIn</a>
					<a class="text-link" href="https://scholar.google.com/citations?user=QeKFlyQAAAAJ" target="_blank" rel="noreferrer">Scholar</a>
					<a class="text-link" href="#about">Top</a>
				</div>
			</footer>
		</div>
	</body>
</html>
