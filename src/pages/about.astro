---
import AcademicPage from '../layouts/AcademicPage.astro';
---

<AcademicPage
	currentPath="/about/"
	title="About"
	description="About Maximos Skandalis, a doctoral researcher in AI at LIRMM, CNRS and the University of Montpellier."
	eyebrow="01 / About"
	heading="Language reasoning, made"
	emphasis="rigorous."
	intro="A doctoral research practice at the junction of large language models, logic, and linguistic formalisms."
>
	<section class="page-section" aria-labelledby="profile-heading">
		<div class="page-section-label"><span>Profile</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="profile-heading">A concern for reliable <em>language technology.</em></h2>
			<div class="detail-prose-stack">
				<p>
					I am a last-year PhD student in artificial intelligence at LIRMM, CNRS and the University of
					Montpellier. My research combines large language models with logic and linguistic formalisms for
					natural language inference and automatic contradiction detection.
				</p>
				<p>
					I work toward language technologies that remain legible and dependable in high-stakes settings,
					where formal reasoning, data quality, and careful evaluation matter as much as raw capability.
				</p>
			</div>
		</div>
	</section>

	<section class="page-section" aria-labelledby="affiliation-heading">
		<div class="page-section-label"><span>Affiliation</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="affiliation-heading">Research context</h2>
			<div class="academic-list">
				<article class="academic-item">
					<div class="academic-meta"><span>Current</span><span>Position</span></div>
					<div>
						<h3>Doctoral researcher in artificial intelligence</h3>
						<p>LIRMM, CNRS and the University of Montpellier, France.</p>
					</div>
				</article>
				<article class="academic-item">
					<div class="academic-meta"><span>Current</span><span>Funding</span></div>
					<div>
						<h3>Defence Innovation Agency and Cybersecurity Institute of Occitanie</h3>
						<p>
							Doctoral research funded by the French Ministry of the Armed Forces through the Defence Innovation
							Agency and by the Cybersecurity Institute of Occitanie.
						</p>
					</div>
				</article>
			</div>
		</div>
	</section>

	<section class="page-section" aria-labelledby="contact-heading">
		<div class="page-section-label"><span>Contact</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="contact-heading">Find the work</h2>
			<div class="link-rail">
