---
import {
	collectiveResponsibilities,
	memberships,
	organisationalResponsibilities,
	responsibilityItems,
	reviewingAssignments,
	supervisionProjects,
} from '../data/academic';
import AcademicPage from '../layouts/AcademicPage.astro';
---

<AcademicPage
	currentPath="/responsibilities/"
	title="Responsibilities"
	description="Academic responsibilities of Maximos Skandalis across research, teaching, supervision, and public-interest AI."
	eyebrow="05 / Responsibilities"
	heading="Academic work, held"
	emphasis="responsibly."
	intro="Current responsibilities across doctoral research, university teaching, student supervision, and publicly supported AI research."
>
	<section class="page-section" aria-labelledby="responsibility-heading">
		<div class="page-section-label"><span>Scope</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="responsibility-heading">Research, teaching, and <em>supervision.</em></h2>
			<div class="academic-list">
				{
					responsibilityItems.map((item) => (
						<article class="academic-item">
							<div class="academic-meta"><span>{item.period}</span><span>{item.category}</span></div>
							<div>
								<h3>{item.title}</h3>
								<p>{item.detail}</p>
							</div>
							{item.href && <a class="academic-link" href={item.href}>{item.linkLabel}</a>}
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="page-section" aria-labelledby="organisation-heading">
		<div class="page-section-label"><span>Organisation</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="organisation-heading">Organisational <em>responsibilities.</em></h2>
			<div class="academic-list">
				{
					organisationalResponsibilities.map((item) => (
						<article class="academic-item">
							<div class="academic-meta"><span>{item.period}</span><span>{item.category}</span></div>
							<div>
								<h3>{item.title}</h3>
								<p>{item.detail}</p>
							</div>
							{
								item.links && (
									<div class="academic-link-group">
										{item.links.map((link) => (
											<a class="academic-link" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
										))}
									</div>
								)
							}
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="page-section" aria-labelledby="reviewing-heading">
		<div class="page-section-label"><span>Reviewing</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="reviewing-heading">Peer review</h2>
			<div class="academic-list">
				{
					reviewingAssignments.map((item) => (
						<article class="academic-item">
							<div class="academic-meta"><span>{item.period}</span><span>{item.category}</span></div>
							<div>
								<h3>{item.title}</h3>
								<p>{item.detail}</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="page-section" aria-labelledby="service-heading">
		<div class="page-section-label"><span>Academic service</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="service-heading">Collective <em>responsibilities.</em></h2>
			<div class="academic-list">
				{
					collectiveResponsibilities.map((item) => (
						<article class="academic-item">
							<div class="academic-meta"><span>{item.period}</span><span>{item.category}</span></div>
							<div>
								<h3>{item.title}</h3>
								<p>{item.detail}</p>
							</div>
							{
								item.links && (
									<div class="academic-link-group">
										{item.links.map((link) => (
											<a class="academic-link" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
										))}
									</div>
								)
							}
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="page-section" aria-labelledby="memberships-heading">
		<div class="page-section-label"><span>Memberships</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="memberships-heading">Scholarly and civic <em>communities.</em></h2>
			<div class="academic-list">
				{
					memberships.map((membership) => (
						<article class="academic-item">
							<div class="academic-meta"><span>{membership.period}</span><span>Membership</span></div>
							<div>
								<h3>{membership.title}</h3>
								<p>{membership.detail}</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="page-section" aria-labelledby="projects-heading">
		<div class="page-section-label"><span>Projects</span></div>
		<div class="page-section-content">
			<h2 class="page-section-title" id="projects-heading">Supervision in <em>practice.</em></h2>
			<div class="academic-list">
				{
					supervisionProjects.map((project) => (
						<article class="academic-item">
							<div class="academic-meta"><span>{project.year}</span><span>Supervision</span></div>
							<div>
								<h3>{project.title}</h3>
								<p>{project.detail}</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>
</AcademicPage>