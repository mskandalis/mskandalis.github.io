---
import { education, publications, researchTalks, responsibilityItems, supervisionProjects, teachingGroups } from '../data/academic';
import '../styles/global.css';

type CvEntry = {
	title: string;
	detail: string;
	date: string;
	href?: string;
	linkLabel?: string;
};

type CvSection = {
	label: string;
	summary?: string;
	entries?: CvEntry[];
};

const cvSections: CvSection[] = [
	{
		label: 'Research interests',
		summary:
			'Neurosymbolic AI for natural language inference and automatic contradiction detection: combining LLMs, logic, and linguistic formalisms for reliable language technology.',
	},
	{
		label: 'Experience',
		entries: [
			{
				title: 'Doctoral researcher in artificial intelligence',
				detail:
					'Last-year Ph.D. student at LIRMM, CNRS and the University of Montpellier. Research on NLI, contradiction detection, and high-stakes language AI.',
				date: 'Current',
			},
		],
	},
	{
		label: 'Education',
		entries: education.map((item) => ({ title: item.title, detail: item.detail, date: item.year })),
	},
	{
		label: 'Publications',
		entries: publications.map((publication) => ({
			title: publication.title,
			detail: `${publication.authors} ${publication.venue}`,
			date: publication.year,
			href: publication.href,
			linkLabel: publication.linkLabel,
		})),
	},
	{
		label: 'Teaching / 272 h',
		entries: teachingGroups.flatMap((group) =>
			group.assignments.map((assignment) => ({
				title: `${group.label}: ${assignment.title}`,
				detail: `${assignment.programme}. ${assignment.institution}`,
				date: `${assignment.year} / ${assignment.hours}`,
			})),
		),
	},
	{
		label: 'Supervision',
		entries: supervisionProjects.map((project) => ({ title: project.title, detail: project.detail, date: project.year })),
	},
	{
		label: 'Talks',
		entries: researchTalks.map((talk) => ({
			title: talk.title,
			detail: talk.detail,
			date: talk.date,
			href: talk.href,
			linkLabel: talk.linkLabel,
		})),
	},
	{
		label: 'Responsibilities and funding',
		entries: responsibilityItems.map((item) => ({
			title: item.title,
			detail: item.detail,
			date: item.period,
			href: item.href,
			linkLabel: item.linkLabel,
		})),
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Curriculum vitae of Maximos Skandalis." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap"
			rel="stylesheet"
		/>
		<title>CV - Maximos Skandalis</title>
	</head>
	<body>
		<main class="cv-page">
			<header class="cv-page-header">
				<a class="cv-back" href="/">Portfolio</a>
				<button class="cv-print" type="button">Print / save PDF</button>
			</header>

			<section class="cv-intro">
				<h1 class="cv-name">Maximos<br /><em>Skandalis</em></h1>
				<div class="cv-intro-copy">
					<div class="micro-label">Curriculum vitae / 2026</div>
					<p>Last-year Ph.D. researcher in AI at LIRMM, CNRS and the University of Montpellier.</p>
					<a class="cv-contact" href="mailto:maximos.skandalis@cnrs.fr">
						maximos.skandalis@cnrs.fr
					</a>
				</div>
			</section>

			<div class="cv-body">
				{
					cvSections.map((section) => (
						<section class="cv-section">
							<div class="cv-section-label">{section.label}</div>
							<div>
								{section.summary && <p class="cv-summary">{section.summary}</p>}
								{
									section.entries && (
										<div class="cv-entry-list">
											{section.entries.map((entry) => (
												<article class="cv-entry">
													<div>
														<h3>{entry.title}</h3>
														<p>{entry.detail}</p>
														{
															entry.href && (
																<a class="cv-entry-link" href={entry.href} target="_blank" rel="noreferrer">
																	{entry.linkLabel ?? 'Read more'}
																</a>
															)
														}
													</div>
													<div class="cv-entry-date">{entry.date}</div>
												</article>
											))}
										</div>
									)
								}
							</div>
						</section>
					))
				}
				<p class="cv-footnote">Last updated July 2026. This CV grows with the work.</p>
			</div>
		</main>

		<script>
			document.querySelector<HTMLButtonElement>('.cv-print')?.addEventListener('click', () => window.print());
		</script>
	</body>
</html>